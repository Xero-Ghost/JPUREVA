# Frontend environment variables
# Use this to point the React/Vite app at your backend during development.
# Example: VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_BASE_URL=

# If you do not set VITE_API_BASE_URL, the frontend will default to:
# - http://localhost:5000/api when running on localhost / 127.0.0.1 / 0.0.0.0
# - http://<current-hostname>:5000/api otherwise
