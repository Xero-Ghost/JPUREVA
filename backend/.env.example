# Copy this file to .env and fill in values
# Database (optional)
# DB_USER=postgres
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=Jindal

# Email settings for sending verification and reset emails
# For Gmail use smtp.gmail.com and port 587
EMAIL_USER=jpureva@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Optional legacy values for SMTP variable names
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=jpureva@gmail.com
# SMTP_PASS=your_app_password_here

# Optional: If your frontend is hosted separately, set FRONTEND_URL to build email links.
# FRONTEND_URL=http://localhost:5173
# Optional: If your backend is hosted separately, set BACKEND_URL for verification links.
# BACKEND_URL=http://localhost:5000

# Note: For Gmail accounts with 2FA, create an App Password and use it as EMAIL_PASSWORD.
# Do NOT commit your real .env file to version control. Keep credentials secret.

# Google OAuth (for Sign in with Google)
# Get these from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-backend-url.com/api/auth/google/callback
